<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.aiolife.llm.mapper.LLMKeyMapper">

    <select id="selectByUserId" resultType="top.aiolife.llm.pojo.entity.LLMKeyEntity">
        SELECT * FROM llm_key WHERE user_id = #{userId} ORDER BY is_default DESC, create_time DESC
    </select>

    <select id="selectDefaultByUserId" resultType="top.aiolife.llm.pojo.entity.LLMKeyEntity">
        SELECT * FROM llm_key WHERE user_id = #{userId} AND is_default = 1
    </select>

</mapper>
